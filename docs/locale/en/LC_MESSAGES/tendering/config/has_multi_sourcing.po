#~ msgstr ""

#~ msgid "`bid.items.unit.code` повинна збігатися з `tender.items.unit.code`. Інакше повертається помилка::"
#~ msgstr ""

#~ msgid "можливо мати більше ніж одну активну аварду в межах тендеру/лоту;"
#~ msgstr ""

#~ msgid "`bid.items.unit.code` повинна збігатися з `tender.items.unit.code`;"
#~ msgstr ""

